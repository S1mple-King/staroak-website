{
  "name": "staroak-official-website",
  "version": "3.4.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "build:check": "npm run typecheck && npm run build",
    "serve:prod": "next start -p ${PORT:-3000}",
    "docker:build": "docker build -t staroak-website:3.4 .",
    "docker:run": "docker run --rm -p 3000:3000 --env-file .env.production staroak-website:3.4"
  },
  "dependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "gsap": "^3.15.0",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5"
  }
}
