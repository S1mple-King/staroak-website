# StarOak official website environment template
# Copy to .env.local for local dev or .env.production for production.

NEXT_PUBLIC_SITE_URL=https://www.staroakx.com
NODE_ENV=production
PORT=3000

# Strapi CMS
STRAPI_API_URL=
STRAPI_API_TOKEN=

# Lead notification webhook: WeCom / DingTalk / Feishu / custom API
LEAD_NOTIFY_WEBHOOK_URL=

# Revalidate secret for /api/revalidate
REVALIDATE_SECRET=replace-with-long-random-secret

# Optional: anti-spam / captcha future integration
CAPTCHA_SECRET=

# Operational contact placeholders. Do not store passwords here.
SITE_OPS_OWNER=
LEAD_OWNER_EMAIL=info@staroakx.com
COMPLIANCE_OWNER=CTO
